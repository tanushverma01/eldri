{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eldri",
  "version": "0.1.0",
  "identifier": "com.hp1.eldri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Eldri Dashboard",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "url": "index.html",
        "decorations": false
      },
      {
        "label": "widget",
        "title": "Eldri Godmode",
        "width": 380,
        "height": 520,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true,
        "shadow": true,
        "url": "widget.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["eldri"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
